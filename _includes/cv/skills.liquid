{% comment %}
  Unified skills entry renderer.
  - RenderCV v2 one_line_entry: label, details
  - Legacy RenderCV / JSONResume: name, level, keywords
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="skill-item">
      {% if entry.icon %}
        <i class="{{ entry.icon }}"></i>
      {% endif %}
      {% capture skill_label %}
        {% if entry.label %}{{ entry.label }}{% elsif entry.name %}{{ entry.name }}{% endif %}
      {% endcapture %}
      <strong>
        {{- skill_label | strip -}}
        {%- if entry.level %} ({{ entry.level }}){% endif %}:</strong
      >
      {% if entry.details %}
        {{ entry.details }}
      {% elsif entry.keywords %}
        {% for keyword in entry.keywords %}
          {% if forloop.last %}
            {{ keyword }}
          {% else %}
            {{ keyword }},
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .skill-item {
    padding: 0.5rem 0;
  }
</style>
